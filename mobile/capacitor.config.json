{
  "appId": "com.himup.field",
  "appName": "HiMup Field",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "buildOptions": {
      "keystorePath": "himup-field.keystore",
      "keystoreAlias": "himup-field"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    }
  }
}
